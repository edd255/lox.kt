class Foo {
    getClosure() {
        fn f() {
            fn g() {
                fn h() {
                    return this.toString();
                }
                return h;
            }
            return g;
        }
        return f;
    }

    toString() { return "Foo"; }
}

var closure = Foo().getClosure();
print closure()()(); // expect: Foo
