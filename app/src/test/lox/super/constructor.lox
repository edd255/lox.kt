class Base {
    init(a, b) {
        print "Base.init(" + a + ", " + b + ")";
    }
}

class Derived : Base {
    init() {
        print "Derived.init()";
        super.init("a", "b");
    }
}

Derived();
// expect: Derived.init()
// expect: Base.init(a, b)
